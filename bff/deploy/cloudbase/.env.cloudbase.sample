ENV=dev
ENABLE_DEV_ENDPOINTS=true
STRICT_STARTUP_VALIDATION=false
DB_AUTO_CREATE_TABLES=true
AUTO_APPLY_MIGRATIONS=false

SECRET_KEY=replace_with_64_random_chars
WECHAT_APP_ID=wx0bfeb41d1fdc1999
WECHAT_APP_SECRET=replace_with_wechat_secret

# 二选一：
# 方案A（推荐）直接填 DATABASE_URL
# DATABASE_URL=mysql+pymysql://root:password@db-host:3306/flask_demo?charset=utf8mb4

# 方案B（兼容 wxcloudrun-flask）填 MYSQL_*，程序会自动拼 DATABASE_URL
MYSQL_ADDRESS=10.22.107.252:3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_DATABASE=flask_demo

REDIS_URL=redis://:password@redis-host:6379/0

WEBHOOK_SHARED_SECRET=replace_with_random_secret
PAYMENT_WEBHOOK_SECRET=replace_with_random_secret
ENABLE_MOCK_PAYMENT=true

ODOO_URL=https://odoo.your-domain.com
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=replace_with_odoo_password

MINIO_ENDPOINT=https://minio.your-domain.com
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=drmoto
