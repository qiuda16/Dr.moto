BFF_ENV=prod
BFF_SECRET_KEY=prod_secret_key_please_replace_with_64_random_chars
BFF_ADMIN_PASSWORD=prod_admin_password_replace_before_go_live
BFF_WEBHOOK_SHARED_SECRET=prod_webhook_shared_secret_replace_before_go_live
BFF_PAYMENT_PROVIDER=mock
BFF_PAYMENT_WEBHOOK_SECRET=prod_payment_webhook_secret_replace_before_go_live
BFF_DB_AUTO_CREATE_TABLES=false
BFF_AUTO_APPLY_MIGRATIONS=false
BFF_STRICT_STARTUP_VALIDATION=true
BFF_DEFAULT_STORE_ID=default
BFF_ENABLE_DEV_ENDPOINTS=false
BFF_ENABLE_MOCK_PAYMENT=false
BFF_WECHAT_APP_ID=wx_your_mini_program_appid
BFF_WECHAT_APP_SECRET=your_wechat_app_secret
BFF_DATABASE_URL=postgresql://user:password@db-host:5432/bff
