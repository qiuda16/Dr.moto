# Minimal required environment for MP customer backend delivery

# Core
BFF_ENV=prod
BFF_SECRET_KEY=replace_with_64_random_chars
BFF_DATABASE_URL=postgresql://odoo:odoo@db:5432/bff
BFF_REDIS_URL=redis://redis:6379/0
BFF_DEFAULT_STORE_ID=default

# Security
BFF_ADMIN_USERNAME=admin
BFF_ADMIN_PASSWORD=replace_admin_password
BFF_WEBHOOK_SHARED_SECRET=replace_webhook_secret
BFF_PAYMENT_WEBHOOK_SECRET=replace_payment_webhook_secret

# Startup / Release
BFF_DB_AUTO_CREATE_TABLES=false
BFF_AUTO_APPLY_MIGRATIONS=false
BFF_STRICT_STARTUP_VALIDATION=true
BFF_ENABLE_DEV_ENDPOINTS=false
BFF_ENABLE_MOCK_PAYMENT=false

# MP Customer WeChat login
BFF_WECHAT_APP_ID=wx_your_app_id
BFF_WECHAT_APP_SECRET=your_wechat_app_secret
