POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me
ODOO_IMAGE=odoo:18.0
POSTGRES_DB=odoo
POSTGRES_MULTIPLE_DATABASES=odoo,bff
ODOO_USER=admin
ODOO_PASSWORD=admin
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=drmoto

BFF_ENV=prod
BFF_LOG_LEVEL=INFO
BFF_LOG_FORMAT=json
BFF_ENABLE_METRICS=true
BFF_METRICS_PATH=/metrics
BFF_DEFAULT_STORE_ID=default
BFF_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
BFF_ENABLE_DEV_ENDPOINTS=false
BFF_ENABLE_MOCK_PAYMENT=false
BFF_PAYMENT_PROVIDER=mock
BFF_PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
BFF_WECHAT_MCH_ID=
BFF_WECHAT_APP_ID=
BFF_WECHAT_API_V3_KEY=
BFF_WECHAT_CERT_SERIAL_NO=
BFF_WECHAT_MCH_PRIVATE_KEY_PEM=
BFF_WECHAT_MCH_PRIVATE_KEY_PATH=
BFF_WECHAT_NOTIFY_URL=
BFF_WECHAT_API_BASE=https://api.mch.weixin.qq.com
BFF_WECHAT_TIMEOUT_SECONDS=10
BFF_WECHAT_PLATFORM_CERT_SERIAL_NO=
BFF_WECHAT_PLATFORM_PUBLIC_KEY_PEM=
BFF_WECHAT_PLATFORM_PUBLIC_KEY_PATH=
BFF_SECRET_KEY=replace_with_long_random_secret
BFF_ADMIN_USERNAME=admin
BFF_ADMIN_EMAIL=admin@yourshop.local
BFF_ADMIN_ROLE=admin
BFF_ADMIN_PASSWORD=replace_with_strong_password
# Optional: prefer hash over plain password in production.
BFF_ADMIN_PASSWORD_HASH=
BFF_WEBHOOK_SHARED_SECRET=replace_with_webhook_secret
BFF_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
BFF_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
BFF_STRICT_STARTUP_VALIDATION=true
BFF_DB_POOL_SIZE=10
BFF_DB_MAX_OVERFLOW=20
BFF_DB_POOL_TIMEOUT_SECONDS=30
BFF_DB_POOL_RECYCLE_SECONDS=1800
BFF_DB_POOL_PRE_PING=true
BFF_DB_AUTO_CREATE_TABLES=false
BFF_MIGRATIONS_DIR=migrations/versions
BFF_AUTO_APPLY_MIGRATIONS=false
BFF_ODOO_TIMEOUT_SECONDS=10
BFF_ODOO_RETRY_MAX_ATTEMPTS=3
BFF_ODOO_RETRY_BACKOFF_SECONDS=0.5
AI_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=qwen3:4b
OLLAMA_CONTEXT_WINDOW=40960
OLLAMA_TIMEOUT_SECONDS=120
AI_CHAT_HISTORY_LIMIT=16
AI_CONTEXT_PAYLOAD_MAX_CHARS=16000
AI_MEMORY_BACKEND=redis
AI_MEMORY_REDIS_URL=redis://redis:6379/1
AI_MEMORY_KEEP_RECENT_TURNS=12
AI_KB_COLLECTION_NAME=real_manual_test
